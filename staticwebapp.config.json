{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/static/media/*", "/static/css/*", "/static/js/*", "*.{png,jpg,gif,ico,svg}", "/api/*"]
  },
  "routes": [
    {
      "route": "/admin",
      "rewrite": "/index.html",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/admin/*",
      "rewrite": "/index.html",
      "allowedRoles": ["authenticated"]
    }
  ],
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html",
      "statusCode": 200
    }
  }
} 